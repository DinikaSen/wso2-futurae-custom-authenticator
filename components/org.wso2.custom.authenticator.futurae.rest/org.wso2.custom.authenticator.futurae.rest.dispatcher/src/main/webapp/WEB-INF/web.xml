<?xml version="1.0" encoding="UTF-8"?>
<web-app version="2.5" xmlns="http://java.sun.com/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee
	http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd">

    <display-name>Futurae Authenticator REST API</display-name>
    <description>Futurae Authenticator REST API</description>

    <context-param>
        <param-name>contextConfigLocation</param-name>
        <param-value>WEB-INF/beans.xml</param-value>
    </context-param>

    <servlet>
        <servlet-name>CXFServlet</servlet-name>
        <servlet-class>
            org.apache.cxf.jaxrs.servlet.CXFNonSpringJaxrsServlet
        </servlet-class>
        <load-on-startup>1</load-on-startup>
        <init-param>
            <param-name>jaxrs.serviceClasses</param-name>
            <param-value>
                org.wso2.custom.authenticator.futurae.rest.v1.AuthenticationApi
            </param-value>
        </init-param>
        <init-param>
            <param-name>jaxrs.providers</param-name>
            <param-value>
                org.wso2.carbon.identity.servlet.mgt.CustomJacksonJsonProvider,
                org.wso2.custom.authenticator.futurae.rest.dispatcher.JsonProcessingExceptionMapper,
                org.wso2.custom.authenticator.futurae.rest.dispatcher.APIErrorExceptionMapper,
                org.wso2.custom.authenticator.futurae.rest.dispatcher.InputValidationExceptionMapper,
                org.wso2.custom.authenticator.futurae.rest.dispatcher.DefaultExceptionMapper
            </param-value>
        </init-param>
        <init-param>
            <param-name>jaxrs.inInterceptors</param-name>
            <param-value>
                org.wso2.carbon.identity.servlet.mgt.CustomBeanValidationInterceptor
            </param-value>
        </init-param>
    </servlet>

    <servlet-mapping>
        <servlet-name>CXFServlet</servlet-name>
        <url-pattern>/v1/*</url-pattern>
    </servlet-mapping>
</web-app>
